{
  "profile": "high_convergence",
  "description": "Aggressive restarts for sparse SNP coverage where convergence < 70%. Use when loci pass rate < 5% or convergence stability fails.",
  "params": {
    "restarts": 500,
    "seed": 42,
    "threads": 8,
    "clustering_method": "em",
    "initialization_strategy": "random_uniform",
    "souporcell3": false,
